// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  phone         String?
  address       String?
  role          String?   @default("user")
  banned        Boolean   @default(false)
  banReason     String?
  banExpires    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  members     Member[]
  invitations Invitation[]
  tickets     Ticket[]
  assignedTasks Task[] @relation("TaskAssignee")
  createdTasks  Task[] @relation("TaskCreator")
  sentFreelancerInvites FreelancerInvite[] @relation("FreelancerInviteSender")
  payouts       Payout[] @relation("PayoutFreelancer")
  decidedPayouts Payout[] @relation("PayoutDecidedBy")
  walletTransactions WalletTransaction[] @relation("WalletUser")
  decidedWalletTxs   WalletTransaction[] @relation("WalletDecidedBy")

  @@unique([email])
  @@map("user")
}

model FreelancerInvite {
  id           String    @id @default(cuid())
  email        String
  invitedById  String    @map("invited_by_id")
  invitedBy    User      @relation("FreelancerInviteSender", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedAt   DateTime? @map("accepted_at")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
  @@map("freelancer_invite")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  activeOrganizationId String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Organization {
  id          String        @id @default(cuid())
  name        String
  slug        String
  logo        String?
  createdAt   DateTime
  metadata    String?
  status      CompanyStatus @default(pending)
  members     Member[]
  invitations Invitation[]
  country     String?      @map("country")
  sicCode     String?      @map("sic_code")
  sicDescription String?   @map("sic_description")
  website        String?
  packageId      String?
  serviceIds     String[]
  companyId String?   @map("company_id")
  authCode       String?   @map("auth_code")
  type           OrganizationType @default(company) @map("type")
  deletedAt      DateTime? @map("deleted_at")
  confirmationStatementDue DateTime? @map("confirmation_statement_due")
  accountsFilingDue        DateTime? @map("accounts_filing_due")
  stateFilingDue           DateTime? @map("state_filing_due")
  federalFilingDue         DateTime? @map("federal_filing_due")
  stateTaxDue              DateTime? @map("state_tax_due")
  directors      Director[]
  documents      Document[]
  invoices       Invoice[]
  serviceOrders  ServiceOrder[]
  mails          Mail[]
  tickets        Ticket[]
  tasks          Task[]

  @@unique([slug])
  @@map("organization")
}

model Director {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  firstName      String
  lastName       String
  email          String
  phone          String
  dateOfBirth    String
  address        String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@map("director")
}

enum DocumentStatus {
  requested
  submitted
  approved
  rejected
}

enum CompanyStatus {
  pending
  processing
  completed
  rejected
}

enum OrganizationType {
  company
  personal
}

enum PaymentStatus {
  unpaid
  processing
  paid
  rejected
}

enum ServiceOrderStatus {
  pending
  processing
  completed
  awaiting_quote
}

enum ServiceType {
  general
  wordpress
}

model Document {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  value          String?
  status         DocumentStatus  @default(submitted)
  requestReason  String?
  rejectReason   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([organizationId])
  @@map("document")
}

model Member {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member")
  createdAt      DateTime

  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String       @default("pending")
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

model Package {
  id          String   @id @default(cuid())
  title       String
  description String
  country     String
  features    String[]
  price       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("package")
}

model Service {
  id            String         @id @default(cuid())
  title         String
  description   String
  features      String[]
  price         Float
  country       String?
  type          ServiceType    @default(general)
  serviceOrders ServiceOrder[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("service")
}

model Theme {
  id            String         @id @default(cuid())
  title         String
  description   String
  image         String?
  demoUrl       String?        @map("demo_url")
  serviceOrders ServiceOrder[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("theme")
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("setting")
}

model Invoice {
  id             String        @id @default(cuid())
  number         Int           @unique @default(autoincrement())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  amount         Float
  description    String?
  items          Json?
  receiverName   String?       @map("receiver_name")
  receiverEmail  String?       @map("receiver_email")
  paymentMethod  String?       @map("payment_method")
  transactionId  String?       @map("transaction_id")
  status         PaymentStatus @default(unpaid)
  rejectReason   String?       @map("reject_reason")
  deletedAt      DateTime?     @map("deleted_at")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  walletTransactions WalletTransaction[]

  @@index([organizationId])
  @@map("invoice")
}

enum TicketStatus {
  open
  pending
  closed
}

model Ticket {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization?   @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  subject        String
  status         TicketStatus    @default(open)
  messages       TicketMessage[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([userId])
  @@index([organizationId])
  @@map("ticket")
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId    String
  fromAdmin   Boolean  @default(false)
  body        String
  attachments String[]
  createdAt   DateTime @default(now())

  @@index([ticketId])
  @@map("ticket_message")
}

model Mail {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  from           String
  subject        String
  body           String
  attachments    String[]
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@map("mail")
}

model ServiceOrder {
  id              String             @id @default(cuid())
  organizationId  String
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  serviceId       String
  service         Service            @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  invoiceId       String?
  status          ServiceOrderStatus @default(pending)
  themeId         String?            @map("theme_id")
  theme           Theme?             @relation(fields: [themeId], references: [id], onDelete: SetNull)
  customDesignUrl String?            @map("custom_design_url")
  credentials     Json?
  contactCompany  String?            @map("contact_company")
  contactAddress  String?            @map("contact_address")
  contactEmail    String?            @map("contact_email")
  contactPhone    String?            @map("contact_phone")
  tasks           Task[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([organizationId])
  @@map("service_order")
}

enum TaskPriority {
  low
  medium
  high
}

enum TaskStatus {
  todo
  in_progress
  blocked
  done
}

model Task {
  id             String        @id @default(cuid())
  title          String
  description    String
  priority       TaskPriority  @default(medium)
  status         TaskStatus    @default(todo)
  deadline       DateTime?
  payoutAmount   Float?        @map("payout_amount")
  assignedToId   String        @map("assigned_to_id")
  assignedTo     User          @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: Cascade)
  createdById    String?       @map("created_by_id")
  createdBy      User?         @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  orderId        String?       @map("order_id")
  order          ServiceOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([assignedToId])
  @@index([status])
  @@map("task")
}

enum PayoutStatus {
  pending
  approved
  rejected
}

model Notification {
  id        String    @id @default(cuid())
  kind      String
  title     String
  body      String?
  link      String?
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([readAt])
  @@index([createdAt])
  @@map("notification")
}

model Payout {
  id           String       @id @default(cuid())
  freelancerId String       @map("freelancer_id")
  freelancer   User         @relation("PayoutFreelancer", fields: [freelancerId], references: [id], onDelete: Cascade)
  amount       Float
  status       PayoutStatus @default(pending)
  method       String
  bankDetails  Json         @map("bank_details")
  note         String?
  adminNote    String?      @map("admin_note")
  decidedAt    DateTime?    @map("decided_at")
  decidedById  String?      @map("decided_by_id")
  decidedBy    User?        @relation("PayoutDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([freelancerId])
  @@index([status])
  @@map("payout")
}

model EmailTemplate {
  id        String   @id @default(cuid())
  event     String   @unique
  subject   String
  heading   String
  intro     String
  ctaLabel  String?  @map("cta_label")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("email_template")
}

enum WalletTxType {
  topup
  payout
  invoice_payment
}

enum WalletTxStatus {
  pending
  approved
  rejected
}

model WalletTransaction {
  id            String         @id @default(cuid())
  userId        String         @map("user_id")
  user          User           @relation("WalletUser", fields: [userId], references: [id], onDelete: Cascade)
  type          WalletTxType
  status        WalletTxStatus @default(pending)
  amount        Float
  method        String?
  transactionId String?        @map("transaction_id")
  bankDetails   Json?          @map("bank_details")
  invoiceId     String?        @map("invoice_id")
  invoice       Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  note          String?
  adminNote     String?        @map("admin_note")
  decidedAt     DateTime?      @map("decided_at")
  decidedById   String?        @map("decided_by_id")
  decidedBy     User?          @relation("WalletDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([userId])
  @@index([status])
  @@index([type])
  @@map("wallet_transaction")
}
